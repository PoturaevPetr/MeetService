# Скопируйте в .env рядом с docker-compose.yml:
#   cp .env.docker.example .env

# Обязательно совпадает с ChatService — иначе клиентские токены не пройдут.
JWT_SECRET_KEY=

# Порт MeetService на хосте
MEET_PORT=8480

# Postgres в compose (хост-порт при необходимости сменить)
MEET_DB_USER=meet
MEET_DB_PASSWORD=meet
MEET_DB_NAME=meet_service
MEET_DB_PORT=5436

# JSON ICE (свой TURN в проде)
# ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]}]

# CORS_ORIGINS=*
