# Совместить с ChatService: скопируйте JWT_SECRET_KEY из ChatService/.env
JWT_SECRET_KEY=

PORT=8480

# Локально без Postgres:
USE_SQLITE=true
SQLITE_PATH=./meet_service.db

# Или Postgres:
# USE_SQLITE=false
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meet_service

# ICE для клиента (JSON-массив). Свой TURN подставьте в проде.
ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]}]

CORS_ORIGINS=*
